  "main": "./build/app.js",
  "scripts": {
    "compile": "rm -rf build || true; tsc",
    "pretest": "rm -rf test/build || true; tsc -p test || true",
    "test": "mocha --reporter mocha-multi-reporters --reporter-options configFile=test/multi-reporters.json",
    "prestart": "npm run compile",
    "start": "node build/app",
    "dev": "tsx --watch src/app.ts",
    "lint": "gts lint */*.ts",
    "clean": "gts clean",
    "fix": "gts fix",
    "prepare": "husky"
  },
  "license": "UNLICENSED",
