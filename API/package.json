    "dotenv": "17.2.3",
    "express": "4.17.1",
    "express-fileupload": "1.2.1",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.1",
    "pg": "^8.16.3",
    "request": "2.88.0",
    "sequelize": "^6.9.0",
    "socket.io": "4.8.1",
    "underscore": "1.13.1",
    "uuid": "8.3.2"
  },
  "devDependencies": {
